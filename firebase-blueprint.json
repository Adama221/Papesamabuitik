{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available for sale in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "wave_payment_link": { "type": "string" },
        "om_payment_link": { "type": "string" },
        "commission": { "type": "number" }
      },
      "required": ["name", "description", "price", "currency", "image", "stock", "category", "wave_payment_link", "commission"]
    },
    "Affiliate": {
      "title": "Affiliate",
      "description": "An affiliate user who earns commissions on sales.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "payment_info": { "type": "string" },
        "earnings": { "type": "number" },
        "sales": { "type": "number" },
        "clicks": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "verified"] }
      },
      "required": ["name", "phone", "payment_info", "earnings", "sales", "clicks", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global store settings.",
      "type": "object",
      "properties": {
        "coverImage": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products collection"
    },
    "/affiliates/{affiliateId}": {
      "schema": { "$ref": "#/entities/Affiliate" },
      "description": "Affiliates collection"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Settings collection"
    }
  }
}
