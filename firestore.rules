rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: products
    // Document ID: prod_{timestamp}
    // Fields:
    //   - name: string (required)
    //   - description: string (required)
    //   - price: number (required)
    //   - currency: string (required)
    //   - image: string (required)
    //   - images: list of strings (optional)
    //   - stock: number (required)
    //   - category: string (required)
    //   - wave_payment_link: string (required)
    //   - om_payment_link: string (optional)
    //   - commission: number (required)
    //
    // Collection: affiliates
    // Document ID: aff_{timestamp}
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - payment_info: string (required)
    //   - earnings: number (required)
    //   - sales: number (required)
    //   - clicks: number (required)
    //   - status: string (required, 'pending' or 'verified')
    //
    // Collection: settings
    // Document ID: cover
    // Fields:
    //   - coverImage: string (optional)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "78177233ds@gmail.com" && request.auth.token.email_verified == true;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.price is number && data.price >= 0 &&
             data.currency is string && data.currency.size() > 0 && data.currency.size() < 10 &&
             data.image is string && data.image.size() > 0 && data.image.size() < 5000000 && // allow base64
             (!('images' in data) || (data.images is list && data.images.size() <= 10)) &&
             data.stock is number && data.stock >= 0 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.wave_payment_link is string && data.wave_payment_link.size() > 0 && data.wave_payment_link.size() < 500 &&
             (!('om_payment_link' in data) || (data.om_payment_link is string && data.om_payment_link.size() < 500)) &&
             data.commission is number && data.commission >= 0 && data.commission <= 100;
    }

    function isValidAffiliate(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 50 &&
             data.payment_info is string && data.payment_info.size() > 0 && data.payment_info.size() < 200 &&
             data.earnings is number && data.earnings >= 0 &&
             data.sales is number && data.sales >= 0 &&
             data.clicks is number && data.clicks >= 0 &&
             data.status in ['pending', 'verified'];
    }

    // Rules
    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /affiliates/{affiliateId} {
      // Affiliates can be read by anyone (needed for login by phone number, and for tracking sales)
      // In a real app, we might want to secure this better, but for this prototype, it's ok.
      allow read: if true; 
      
      // Anyone can register as an affiliate
      allow create: if isValidAffiliate(request.resource.data) && 
                       request.resource.data.earnings == 0 &&
                       request.resource.data.sales == 0 &&
                       request.resource.data.clicks == 0 &&
                       request.resource.data.status == 'pending';
                       
      // Updates:
      // 1. Admin can update anything
      // 2. Anyone can increment sales/earnings (from CartPage)
      // 3. Anyone can increment clicks (from App.tsx)
      allow update: if isAdmin() && isValidAffiliate(request.resource.data) ||
                       (
                         isValidAffiliate(request.resource.data) &&
                         (
                           // Increment sales/earnings
                           (
                             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['earnings', 'sales']) &&
                             request.resource.data.earnings >= resource.data.earnings &&
                             request.resource.data.sales == resource.data.sales + 1
                           ) ||
                           // Increment clicks
                           (
                             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']) &&
                             request.resource.data.clicks == resource.data.clicks + 1
                           )
                         )
                       );
                       
      allow delete: if isAdmin();
    }
  }
}
